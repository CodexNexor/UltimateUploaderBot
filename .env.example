# ─────────────────────────────────────────────────────────────
# Ultimate URL Uploader + Unzip Bot — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Get from https://my.telegram.org
API_ID=your_api_id
API_HASH=your_api_hash

# Your Telegram User ID (get from @userinfobot)
OWNER_ID=your_user_id

# Comma-separated extra admin IDs (optional)
ADMIN_IDS=

# Log channel ID — make bot admin with all rights (optional)
LOG_CHANNEL=0

# Force subscribe channel ID — make bot admin (optional, leave blank to disable)
FORCE_SUB_CHANNEL=

# Download folder path
DOWNLOAD_LOCATION=./DOWNLOADS

# Thumbnail folder path
THUMB_LOCATION=./THUMBNAILS

# Path to ffmpeg binary (default: system ffmpeg)
FFMPEG_PATH=ffmpeg

# Seconds to wait for user confirmation before deleting downloaded files
UPLOAD_CONFIRM_TIMEOUT=300
